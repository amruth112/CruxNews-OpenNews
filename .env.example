# OpenNews Configuration
# All environment variables are OPTIONAL. The app works without any of them.

# No API keys required for core functionality!
# The following are only needed for optional AI enhancements:

# Groq API Key (free at console.groq.com) - for cloud AI summaries FAST
# VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Custom Ollama URL (default: http://localhost:11434)
# VITE_OLLAMA_URL=http://localhost:11434
